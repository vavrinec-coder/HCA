{
  "name": "external-calc-engine-excel-addin",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "certs": "office-addin-dev-certs install",
    "build:functions": "node scripts/build-custom-functions.mjs",
    "verify:functions": "node scripts/verify-custom-functions-generated.mjs",
    "dev": "npm run build:functions && vite --host localhost --port 3000",
    "build": "npm run build:functions && vite build",
    "preview": "vite preview --host localhost --port 3000",
    "test": "node --test src/taskpane/config.test.js src/functions/load-detail.test.js && npm run verify:functions"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "office-addin-dev-certs": "^1.13.5"
  }
}
